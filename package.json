{
  "name": "codex-feishu-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Docker-first monorepo for the Codex and Feishu bridge project.",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start:all": "bash ./scripts/dev-stack.sh up",
    "start:stdio": "bash ./scripts/dev-stack.sh up stdio",
    "start:socket-proxy": "bash ./scripts/dev-stack.sh up socket-proxy",
    "monitor:all": "bash ./scripts/dev-stack.sh monitor",
    "monitor:stdio": "bash ./scripts/dev-stack.sh monitor stdio",
    "monitor:socket-proxy": "bash ./scripts/dev-stack.sh monitor socket-proxy",
    "stop:all": "bash ./scripts/dev-stack.sh down",
    "status:all": "bash ./scripts/dev-stack.sh status",
    "logs:all": "bash ./scripts/dev-stack.sh logs",
    "compose:config": "docker compose -f docker/compose.yaml --env-file docker/.env.example config",
    "dev:up": "docker compose -f docker/compose.yaml --env-file docker/.env.example up -d workspace-dev",
    "dev:shell": "docker compose -f docker/compose.yaml --env-file docker/.env.example exec workspace-dev bash",
    "runtime:up": "docker compose -f docker/compose.yaml --env-file docker/.env.example up -d bridge-runtime",
    "runtime:shell": "docker compose -f docker/compose.yaml --env-file docker/.env.example exec bridge-runtime bash",
    "bridge:cli": "bun scripts/bridge-cli.mjs",
    "feishu:resolve-chat": "bun scripts/resolve-feishu-chat.ts",
    "hub:init": "bun scripts/hub-cli.mjs init",
    "hub:post": "bun scripts/hub-cli.mjs post",
    "hub:broadcast": "bun scripts/hub-cli.mjs broadcast",
    "hub:read": "bun scripts/hub-cli.mjs read",
    "hub:status": "bun scripts/hub-cli.mjs status",
    "hub:doctor": "bun scripts/hub-cli.mjs doctor",
    "validate:runtime": "bun scripts/live-runtime-check.mjs",
    "validate:runtime:container": "BRIDGE_BASE_URL=http://bridge-runtime:8787 bun scripts/live-runtime-check.mjs",
    "build:protocol": "bun run --filter @codex-feishu-bridge/protocol build",
    "build:shared": "bun run --filter @codex-feishu-bridge/shared build",
    "build:daemon": "bun run --filter @codex-feishu-bridge/bridge-daemon build",
    "build:extension": "bun run --filter @codex-feishu-bridge/vscode-extension build",
    "typecheck:protocol": "bun run --filter @codex-feishu-bridge/protocol typecheck",
    "typecheck:shared": "bun run --filter @codex-feishu-bridge/shared typecheck",
    "typecheck:daemon": "bun run --filter @codex-feishu-bridge/bridge-daemon typecheck",
    "typecheck:extension": "bun run --filter @codex-feishu-bridge/vscode-extension typecheck",
    "lint:protocol": "bun run --filter @codex-feishu-bridge/protocol lint",
    "lint:shared": "bun run --filter @codex-feishu-bridge/shared lint",
    "lint:daemon": "bun run --filter @codex-feishu-bridge/bridge-daemon lint",
    "lint:extension": "bun run --filter @codex-feishu-bridge/vscode-extension lint",
    "test:integration": "bun test tests/integration/*.test.mjs",
    "test:protocol": "bun run --filter @codex-feishu-bridge/protocol test",
    "test:shared": "bun run --filter @codex-feishu-bridge/shared test",
    "test:daemon": "bun run --filter @codex-feishu-bridge/bridge-daemon test",
    "test:extension": "bun run --filter @codex-feishu-bridge/vscode-extension test",
    "build": "bun run build:shared && bun run build:protocol && bun run build:daemon && bun run build:extension",
    "typecheck": "bun run typecheck:shared && bun run typecheck:protocol && bun run typecheck:daemon && bun run typecheck:extension",
    "lint": "bun run lint:shared && bun run lint:protocol && bun run lint:daemon && bun run lint:extension",
    "test": "bun run test:integration && bun run test:shared && bun run test:protocol && bun run test:daemon && bun run test:extension"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "js-yaml": "^4.1.1",
    "typescript": "^5.7.2"
  }
}
